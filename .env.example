# Docker Compose Environment Variables Example
# Copy this file to .env and adjust values as needed

# PostgreSQL Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vibeflow
POSTGRES_PORT=5432

# Backend Service Configuration
BACKEND_PORT=8001
SECRET_KEY=change-me-in-production-please-use-a-secure-key
DEBUG=False

# Frontend Service Configuration
FRONTEND_PORT=8080
VITE_API_BASE_URL=http://localhost:8001

# Database URL (used by backend)
DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Notes:
# 1. For production, set a strong SECRET_KEY
# 2. Set DEBUG=False in production
# 3. Adjust ports if they conflict with existing services
# 4. Create .env.local for local overrides (gitignored)